# Secrets are pulled from the local .env file at the repo root.
# .env must NOT be committed to git — it contains the Docker Hub token and API keys.
# Kamal's inline adapter only evaluates command substitution per line, so we
# grep each value out of .env directly instead of sourcing it.

RAILS_MASTER_KEY=$(cat config/master.key)
KAMAL_REGISTRY_PASSWORD=$(grep '^KAMAL_REGISTRY_PASSWORD=' .env | cut -d= -f2-)
SPOTIFY_CLIENT_ID=$(grep '^SPOTIFY_CLIENT_ID=' .env | cut -d= -f2-)
SPOTIFY_CLIENT_SECRET=$(grep '^SPOTIFY_CLIENT_SECRET=' .env | cut -d= -f2-)
GENIUS_ACCESS_TOKEN=$(grep '^GENIUS_ACCESS_TOKEN=' .env | cut -d= -f2-)
YOUTUBE_API_KEY=$(grep '^YOUTUBE_API_KEY=' .env | cut -d= -f2-)
