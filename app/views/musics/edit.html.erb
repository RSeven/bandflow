<div class="max-w-3xl">
  <div class="flex items-center gap-2 text-sm text-zinc-400 mb-4">
    <%= link_to @band.name, band_path(@band), class: "hover:text-zinc-200" %>
    <span>/</span>
    <%= link_to @music.title, band_music_path(@band, @music), class: "hover:text-zinc-200" %>
    <span>/</span>
    <span>Edit</span>
  </div>
  <h1 class="text-2xl font-bold mb-6">Edit music</h1>
  <%= render "form", music: @music, band: @band %>
</div>
