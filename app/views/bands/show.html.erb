<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-3xl font-bold"><%= @band.name %></h1>
    <% if @band.description.present? %>
      <p class="text-zinc-400 mt-1"><%= @band.description %></p>
    <% end %>
  </div>
  <% if Current.user.admin_of?(@band) %>
    <div class="flex gap-2">
      <%= link_to t("common.edit"), edit_band_path(@band), class: "text-sm text-zinc-400 hover:text-zinc-200 border border-zinc-700 px-3 py-1.5 rounded-lg transition-colors" %>
      <%= button_to t("common.delete"), band_path(@band), method: :delete,
          data: { turbo_confirm: t("bands.show.delete_confirm", name: @band.name) },
          class: "text-sm text-red-400 hover:text-red-300 border border-red-800 px-3 py-1.5 rounded-lg transition-colors" %>
    </div>
  <% end %>
</div>

<section class="mb-8">
  <div class="border-b border-zinc-800 mb-5">
    <div class="flex gap-2">
      <%= link_to t("bands.show.tabs.repertoire"), band_path(@band, tab_params("musics")),
          class: [
            "rounded-t-lg px-4 py-2 text-sm font-semibold transition-colors",
            @active_tab == "musics" ? "bg-zinc-900 text-amber-400 border border-b-0 border-zinc-700" : "text-zinc-400 hover:text-zinc-200"
          ].join(" ") %>
      <%= link_to t("bands.show.tabs.setlists"), band_path(@band, tab_params("setlists")),
          class: [
            "rounded-t-lg px-4 py-2 text-sm font-semibold transition-colors",
            @active_tab == "setlists" ? "bg-zinc-900 text-amber-400 border border-b-0 border-zinc-700" : "text-zinc-400 hover:text-zinc-200"
          ].join(" ") %>
    </div>
  </div>

  <% if @active_tab == "musics" %>
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold"><%= t("bands.show.repertoire_title") %></h2>
        <%= link_to t("bands.show.add_music"), new_band_music_path(@band), class: "text-sm text-amber-400 hover:text-amber-300" %>
      </div>

      <div class="flex flex-col gap-3 mb-4 sm:grid sm:grid-cols-2">
        <%= form_with url: band_path(@band), method: :get, local: true,
            data: { controller: "auto-submit", auto_submit_delay_value: 350 },
            class: "flex items-center gap-2" do |form| %>
          <%= form.hidden_field :tab, value: "musics" %>
          <%= form.hidden_field :setlist_page, value: @setlist_page %>
          <%= form.label :music_query, t("bands.show.search_musics_label"), class: "sr-only" %>
          <%= form.text_field :music_query,
              value: @music_query,
              placeholder: t("bands.show.search_musics_placeholder"),
              data: { action: "input->auto-submit#submit" },
              class: "flex-1 bg-zinc-900 border border-zinc-800 focus:border-amber-500 rounded-lg px-3 py-2 text-sm text-zinc-100 placeholder:text-zinc-500" %>
          <% if @music_query.present? %>
            <%= link_to t("common.clear"), band_path(@band, tab: "musics", setlist_page: @setlist_page),
                class: "text-sm text-zinc-400 hover:text-zinc-200 transition-colors" %>
          <% end %>
        <% end %>

        <% if @musics_total_pages > 1 %>
          <div class="flex items-center justify-between text-sm sm:justify-end sm:gap-2">
            <div class="text-zinc-500">
              <%= t("common.page_of", page: @music_page, total: @musics_total_pages) %>
            </div>
            <div class="flex items-center gap-2">
              <% if @music_page > 1 %>
                <%= link_to t("common.previous"), band_path(@band, pagination_params(:music_page, @music_page - 1).merge(tab: "musics")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
              <% if @music_page < @musics_total_pages %>
                <%= link_to t("common.next"), band_path(@band, pagination_params(:music_page, @music_page + 1).merge(tab: "musics")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @musics.empty? %>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 text-center text-zinc-500 text-sm">
          <%= @music_query.present? ? t("bands.show.no_music_search_results") : t("bands.show.no_music_yet") %>
        </div>
      <% else %>
        <div class="space-y-2">
          <% @musics.each do |music| %>
            <%= link_to band_music_path(@band, music), class: "flex items-center justify-between bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-lg px-4 py-3 transition-colors group" do %>
              <div>
                <div class="font-medium group-hover:text-amber-400 transition-colors"><%= music.title %></div>
                <div class="text-zinc-400 text-sm"><%= music.artist %></div>
              </div>
              <div class="flex items-center gap-2 text-xs text-zinc-500">
                <% if music.bpm.present? %>
                  <span class="bg-zinc-800 px-2 py-0.5 rounded"><%= music.bpm_display %> BPM</span>
                <% end %>
                <% if music.key_name.present? %>
                  <span class="bg-zinc-800 px-2 py-0.5 rounded"><%= music.musical_key %></span>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <% if @musics_total_pages > 1 %>
          <div class="mt-4 flex items-center justify-between text-sm">
            <div class="text-zinc-500">
              <%= t("common.page_of", page: @music_page, total: @musics_total_pages) %>
            </div>
            <div class="flex items-center gap-2">
              <% if @music_page > 1 %>
                <%= link_to t("common.previous"), band_path(@band, pagination_params(:music_page, @music_page - 1).merge(tab: "musics")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
              <% if @music_page < @musics_total_pages %>
                <%= link_to t("common.next"), band_path(@band, pagination_params(:music_page, @music_page + 1).merge(tab: "musics")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </section>
  <% else %>
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold"><%= t("bands.show.setlists_title") %></h2>
        <%= link_to t("bands.show.new_setlist"), new_band_setlist_path(@band), class: "text-sm text-amber-400 hover:text-amber-300" %>
      </div>

      <% if @setlists_total_pages > 1 %>
        <div class="mb-4 flex items-center justify-between text-sm">
          <div class="text-zinc-500">
            <%= t("common.page_of", page: @setlist_page, total: @setlists_total_pages) %>
          </div>
          <div class="flex items-center gap-2">
            <% if @setlist_page > 1 %>
              <%= link_to t("common.previous"), band_path(@band, pagination_params(:setlist_page, @setlist_page - 1).merge(tab: "setlists")),
                  class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
            <% end %>
            <% if @setlist_page < @setlists_total_pages %>
              <%= link_to t("common.next"), band_path(@band, pagination_params(:setlist_page, @setlist_page + 1).merge(tab: "setlists")),
                  class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @setlists.empty? %>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 text-center text-zinc-500 text-sm">
          <%= t("bands.show.no_setlists_yet") %>
        </div>
      <% else %>
        <div class="space-y-2">
          <% @setlists.each do |setlist| %>
            <%= link_to band_setlist_path(@band, setlist), class: "flex items-center justify-between bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-lg px-4 py-3 transition-colors group" do %>
              <div>
                <div class="font-medium group-hover:text-amber-400 transition-colors"><%= setlist.title %></div>
                <% if setlist.performance_date.present? %>
                  <div class="text-zinc-400 text-sm"><%= l(setlist.performance_date, format: :long) %></div>
                <% end %>
              </div>
              <span class="text-xs text-zinc-500"><%= t("bands.show.songs_count", count: setlist.music_count) %></span>
            <% end %>
          <% end %>
        </div>

        <% if @setlists_total_pages > 1 %>
          <div class="mt-4 flex items-center justify-between text-sm">
            <div class="text-zinc-500">
              <%= t("common.page_of", page: @setlist_page, total: @setlists_total_pages) %>
            </div>
            <div class="flex items-center gap-2">
              <% if @setlist_page > 1 %>
                <%= link_to t("common.previous"), band_path(@band, pagination_params(:setlist_page, @setlist_page - 1).merge(tab: "setlists")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
              <% if @setlist_page < @setlists_total_pages %>
                <%= link_to t("common.next"), band_path(@band, pagination_params(:setlist_page, @setlist_page + 1).merge(tab: "setlists")),
                    class: "border border-zinc-700 hover:border-zinc-500 rounded-lg px-3 py-1.5 text-zinc-300 transition-colors" %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>
</section>

<%# ——— MEMBERS & INVITE ——— %>
<section class="mt-8 border-t border-zinc-800 pt-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold"><%= t("bands.show.members_title") %></h2>
    <% if Current.user.admin_of?(@band) %>
      <%= button_to t("bands.show.generate_invite"), band_invitations_path(@band), method: :post,
          class: "text-sm bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 px-3 py-1.5 rounded-lg transition-colors" %>
    <% end %>
  </div>
  <div class="flex flex-wrap gap-2">
    <% @band.band_memberships.includes(:user).each do |membership| %>
      <div class="flex items-center gap-2 bg-zinc-900 border border-zinc-800 rounded-lg px-3 py-2 text-sm">
        <span><%= membership.user.name %></span>
        <% if membership.role == "admin" %>
          <span class="text-xs text-amber-400"><%= t("bands.show.admin_badge") %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
