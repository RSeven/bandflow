<div class="max-w-md mx-auto mt-16">
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8">
    <h1 class="text-2xl font-bold mb-1">Sign in</h1>
    <p class="text-zinc-400 text-sm mb-6">Welcome back to Bandflow.</p>

    <%= form_with url: session_url, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
            value: params[:email_address],
            class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent",
            placeholder: "you@example.com" %>
      </div>

      <div>
        <%= form.label :password, class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
            class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" %>
      </div>

      <div class="flex items-center justify-between pt-1">
        <%= form.submit "Sign in", class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2 px-6 rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Forgot password?", new_password_path, class: "text-sm text-zinc-400 hover:text-zinc-200" %>
      </div>
    <% end %>

    <p class="mt-4 text-center text-sm text-zinc-400">
      Don't have an account? <%= link_to "Sign up", new_registration_path, class: "text-amber-400 hover:text-amber-300" %>
    </p>
  </div>
</div>
