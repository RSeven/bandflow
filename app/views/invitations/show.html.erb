<div class="max-w-md mx-auto mt-16">
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8 text-center">
    <div class="text-4xl mb-4">🎸</div>
    <h1 class="text-2xl font-bold mb-2"><%= t("invitations.show.title") %></h1>
    <p class="text-zinc-400 mb-6">
      <%= t("invitations.show.body_html", inviter: @invitation.invited_by.name, band: @invitation.band.name, app: t("app.name")) %>
    </p>

    <% if Current.user %>
      <%= button_to t("invitations.show.accept"), accept_invitation_path(@invitation.token), method: :post,
          class: "w-full bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2.5 px-6 rounded-lg transition-colors" %>
      <p class="mt-3 text-xs text-zinc-500"><%= t("invitations.show.joining_as", email: Current.user.email_address) %></p>
    <% else %>
      <p class="text-zinc-400 text-sm mb-4"><%= t("invitations.show.sign_in_prompt") %></p>
      <div class="flex gap-3 justify-center">
        <%= link_to t("invitations.show.create_account"), new_registration_path, class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2 px-5 rounded-lg text-sm transition-colors" %>
        <%= link_to t("layout.sign_in"), new_session_path, class: "bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 py-2 px-5 rounded-lg text-sm transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
