<div class="max-w-md mx-auto mt-16">
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8 text-center">
    <div class="text-4xl mb-4">🎸</div>
    <h1 class="text-2xl font-bold mb-2">You're invited!</h1>
    <p class="text-zinc-400 mb-6">
      <strong class="text-zinc-200"><%= @invitation.invited_by.name %></strong>
      has invited you to join
      <strong class="text-zinc-200"><%= @invitation.band.name %></strong>
      on Bandflow.
    </p>

    <% if Current.user %>
      <%= button_to "Accept invitation", accept_invitation_path(@invitation.token), method: :post,
          class: "w-full bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2.5 px-6 rounded-lg transition-colors" %>
      <p class="mt-3 text-xs text-zinc-500">Joining as <%= Current.user.email_address %></p>
    <% else %>
      <p class="text-zinc-400 text-sm mb-4">Sign up or sign in to join the band.</p>
      <div class="flex gap-3 justify-center">
        <%= link_to "Create account", new_registration_path, class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2 px-5 rounded-lg text-sm transition-colors" %>
        <%= link_to "Sign in", new_session_path, class: "bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 py-2 px-5 rounded-lg text-sm transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
