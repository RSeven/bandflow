<div class="max-w-md mx-auto mt-16">
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8">
    <h1 class="text-2xl font-bold mb-1">Create your account</h1>
    <p class="text-zinc-400 text-sm mb-6">Join Bandflow and start managing your band's repertoire.</p>

    <%= form_with model: @user, url: registration_path, class: "space-y-4" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-900/40 border border-red-700 text-red-300 rounded-lg px-4 py-3 text-sm">
          <ul class="list-disc list-inside space-y-1">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.text_field :name, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent", placeholder: "Your name" %>
      </div>

      <div>
        <%= f.label :email_address, "Email", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.email_field :email_address, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent", placeholder: "you@example.com" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.password_field :password, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-zinc-300 mb-1" %>
        <%= f.password_field :password_confirmation, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" %>
      </div>

      <%= f.submit "Create account", class: "w-full bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
    <% end %>

    <p class="mt-4 text-center text-sm text-zinc-400">
      Already have an account? <%= link_to "Sign in", new_session_path, class: "text-amber-400 hover:text-amber-300" %>
    </p>
  </div>
</div>
