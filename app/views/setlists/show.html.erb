<div class="max-w-3xl">
  <div class="flex items-center gap-2 text-sm text-zinc-400 mb-4">
    <%= link_to @band.name, band_path(@band), class: "hover:text-zinc-200" %>
    <span>/</span>
    <span class="text-zinc-200"><%= @setlist.title %></span>
  </div>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @setlist.title %></h1>
      <% if @setlist.performance_date.present? %>
        <p class="text-zinc-400 text-sm mt-1"><%= l(@setlist.performance_date, format: :long) %></p>
      <% end %>
      <% if @setlist.notes.present? %>
        <p class="text-zinc-400 text-sm mt-1"><%= @setlist.notes %></p>
      <% end %>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <% unless @setlist_items.empty? %>
        <%= link_to t("setlists.show.present"), present_band_setlist_path(@band, @setlist),
            class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold px-4 py-2 rounded-lg text-sm transition-colors" %>
        <%= link_to t("common.pdf"), band_setlist_path(@band, @setlist, format: :pdf),
            target: "_blank", rel: "noopener",
            class: "text-sm border border-zinc-700 hover:border-zinc-500 px-3 py-2 rounded-lg transition-colors" %>
        <%= link_to t("setlists.show.export_offline"), export_band_setlist_path(@band, @setlist),
            class: "text-sm border border-zinc-700 hover:border-zinc-500 px-3 py-2 rounded-lg transition-colors" %>
      <% end %>
      <%= link_to t("common.edit"), edit_band_setlist_path(@band, @setlist), class: "text-sm border border-zinc-700 hover:border-zinc-500 px-3 py-2 rounded-lg transition-colors" %>
      <%= button_to t("common.delete"), band_setlist_path(@band, @setlist), method: :delete,
          data: { turbo_confirm: t("setlists.show.delete_confirm") },
          class: "text-sm border border-red-800 text-red-400 hover:border-red-600 px-3 py-2 rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <%# ——— Setlist Items ——— %>
    <div class="lg:col-span-2">
      <div id="setlist-items-panel">
        <%= render "setlist_items", band: @band, setlist: @setlist, setlist_items: @setlist_items %>
      </div>
    </div>

    <%# ——— Add Items Panel ——— %>
    <div class="space-y-4">
      <%= render "available_musics",
          band: @band,
          setlist: @setlist,
          musics: @musics,
          music_page: @music_page,
          music_query: @music_query,
          musics_total_pages: @musics_total_pages,
          event_page: @event_page,
          event_query: @event_query %>

      <%= render "available_events",
          band: @band,
          setlist: @setlist,
          events: @events,
          event_page: @event_page,
          event_query: @event_query,
          events_total_pages: @events_total_pages,
          music_page: @music_page,
          music_query: @music_query %>

      <div class="pt-2 space-y-2 border-t border-zinc-800">
        <%= link_to t("setlists.show.add_music_to_repertoire"), new_band_music_path(@band), class: "block text-sm text-amber-400 hover:text-amber-300" %>
        <%= link_to t("setlists.show.create_event"), new_band_event_path(@band), class: "block text-sm text-blue-400 hover:text-blue-300" %>
      </div>
    </div>
  </div>
</div>
