<div class="max-w-3xl">
  <div class="flex items-center gap-2 text-sm text-zinc-400 mb-4">
    <%= link_to @band.name, band_path(@band), class: "hover:text-zinc-200" %>
    <span>/</span>
    <span class="text-zinc-200"><%= @setlist.title %></span>
  </div>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @setlist.title %></h1>
      <% if @setlist.performance_date.present? %>
        <p class="text-zinc-400 text-sm mt-1"><%= @setlist.performance_date.strftime("%B %-d, %Y") %></p>
      <% end %>
      <% if @setlist.notes.present? %>
        <p class="text-zinc-400 text-sm mt-1"><%= @setlist.notes %></p>
      <% end %>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <% unless @setlist_items.empty? %>
        <%= link_to "Present", present_band_setlist_path(@band, @setlist),
            class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold px-4 py-2 rounded-lg text-sm transition-colors" %>
      <% end %>
      <%= link_to "Edit", edit_band_setlist_path(@band, @setlist), class: "text-sm border border-zinc-700 hover:border-zinc-500 px-3 py-2 rounded-lg transition-colors" %>
      <%= button_to "Delete", band_setlist_path(@band, @setlist), method: :delete,
          data: { turbo_confirm: "Delete this setlist?" },
          class: "text-sm border border-red-800 text-red-400 hover:border-red-600 px-3 py-2 rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="grid lg:grid-cols-3 gap-6">
    <%# ——— Setlist Items ——— %>
    <div class="lg:col-span-2">
      <div id="setlist-items-panel">
        <%= render "setlist_items", band: @band, setlist: @setlist, setlist_items: @setlist_items %>
      </div>
    </div>

    <%# ——— Add Items Panel ——— %>
    <div class="space-y-4">
      <%= render "available_musics", band: @band, setlist: @setlist, musics: @musics %>

      <% if @events.any? %>
        <div>
          <h3 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-2">Add Event</h3>
          <div class="space-y-1 max-h-48 overflow-y-auto">
            <% @events.each do |event| %>
              <%= button_to band_setlist_setlist_items_path(@band, @setlist),
                  params: { item_type: "Event", item_id: event.id },
                  data: { turbo_stream: true },
                  class: "w-full text-left bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 border-blue-900/40 rounded-lg px-3 py-2 text-sm transition-colors" do %>
                <div class="font-medium text-blue-300 truncate"><%= event.title %></div>
                <% if event.description.present? %>
                  <div class="text-zinc-400 text-xs truncate"><%= event.description %></div>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="pt-2 space-y-2 border-t border-zinc-800">
        <%= link_to "+ Add music to repertoire", new_band_music_path(@band), class: "block text-sm text-amber-400 hover:text-amber-300" %>
        <%= link_to "+ Create event", new_band_event_path(@band), class: "block text-sm text-blue-400 hover:text-blue-300" %>
      </div>
    </div>
  </div>
</div>
