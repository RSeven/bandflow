<div class="max-w-lg">
  <div class="flex items-center gap-2 text-sm text-zinc-400 mb-4">
    <%= link_to @band.name, band_path(@band), class: "hover:text-zinc-200" %>
    <span>/</span>
    <%= link_to @setlist.title, band_setlist_path(@band, @setlist), class: "hover:text-zinc-200" %>
    <span>/</span>
    <span><%= t("common.edit") %></span>
  </div>
  <h1 class="text-2xl font-bold mb-6"><%= t("setlists.edit.title") %></h1>
  <%= render "form", setlist: @setlist, band: @band %>
</div>
