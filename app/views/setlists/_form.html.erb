<%= form_with model: [ band, setlist ], class: "space-y-4" do |f| %>
  <% if setlist.errors.any? %>
    <div class="bg-red-900/40 border border-red-700 text-red-300 rounded-lg px-4 py-3 text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% setlist.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-zinc-300 mb-1" %>
    <%= f.text_field :title, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent", placeholder: t("setlists.form.title_placeholder") %>
  </div>

  <div>
    <%= f.label :performance_date, t("setlists.form.performance_date"), class: "block text-sm font-medium text-zinc-300 mb-1" %>
    <%= f.date_field :performance_date, class: "bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :notes, t("setlists.form.notes"), class: "block text-sm font-medium text-zinc-300 mb-1" %>
    <%= f.text_area :notes, rows: 3, class: "w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent resize-none" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit class: "bg-amber-500 hover:bg-amber-400 text-black font-semibold py-2 px-6 rounded-lg transition-colors cursor-pointer text-sm" %>
    <%= link_to t("common.cancel"), setlist.persisted? ? band_setlist_path(band, setlist) : band_path(band), class: "text-sm text-zinc-400 hover:text-zinc-200 py-2 px-4" %>
  </div>
<% end %>
